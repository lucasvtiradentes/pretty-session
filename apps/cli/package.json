{
	"name": "@pretty-sessions/cli",
	"version": "0.1.0",
	"description": "Pretty formatter for AI coding agent sessions (Claude Code, Codex, Gemini)",
	"type": "module",
	"bin": {
		"pretty-sessions": "./dist/cli.js",
		"ps": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check": "tsc --noEmit",
		"test": "vitest run",
		"test:replay": "cat tests/fixtures/sample_session.jsonl | node dist/cli.js claude",
		"test:e2e": "cd ../../.sandbox && claude -p \"$(cat ../.github/test-prompt.md)\" --print --verbose --dangerously-skip-permissions --output-format stream-json --include-partial-messages | node ../apps/cli/dist/cli.js claude"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"tsup": "^8.3.6",
		"typescript": "^5.7.3",
		"vitest": "^4.1.4"
	}
}
